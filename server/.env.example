# ============================================================
# ShopVerse Backend — Environment Variables
# ============================================================
# Copy this file to `.env` and fill in your actual values.
# Never commit your real `.env` file to version control!
# ============================================================

# --- Server ---
PORT=3000
# Internal server URL (not usually needed, but kept for reference)
BACKEND_URL=http://localhost:3000

# --- Database ---
# MongoDB Atlas (recommended):
DB_URL=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/shopverse?appName=<appName>
# MongoDB Local (alternative):
# DB_URL=mongodb://localhost:27017/shopverse

# --- Authentication ---
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET_KEY=your_jwt_secret_key_here

# --- CORS ---
# URL of the running frontend (used to whitelist CORS requests)
CLIENT_URL=http://localhost:5173

# --- Stripe Payments ---
# Get this from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here

# --- Google Gemini AI (Chatbot) ---
# Get this from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# --- Email (Forgot Password / Verification) ---
# Supports: gmail, hotmail, yahoo, outlook, sendgrid etc.
# For Gmail: use App Password (not your login password)
# Generate App Password at: https://myaccount.google.com/apppasswords (requires 2FA enabled)
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_16_char_app_password_here
